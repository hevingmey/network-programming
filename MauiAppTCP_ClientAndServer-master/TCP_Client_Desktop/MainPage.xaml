<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TCP_Client_Desktop.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25">

            <Label Text="TCP Client"
                   FontSize="28"
                   HorizontalOptions="Center" />

            <Entry x:Name="AddressEntry"
                   Placeholder="localhost або 192.168.1.10"
                   Text="localhost"/>

            <Entry x:Name="PortEntry"
                   Placeholder="Port"
                   Keyboard="Numeric"
                   Text="5000"/>

            <Button Text="Connect"
                    Clicked="OnConnectClicked"/>

            <Entry x:Name="MessageEntry"
                   Placeholder="Message for server"
                   IsVisible="False"/>

            <Button x:Name="SendBtn"
                    Text="Send"
                    Clicked="OnSendMessageClicked"
                    IsVisible="False"/>

            <Editor x:Name="ContentEditor"
                    IsReadOnly="True"
                    AutoSize="TextChanges"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>